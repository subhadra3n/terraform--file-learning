1️⃣ Provider
provider "google" {
  project = "your-project-id"
  region  = "asia-south1"
  zone    = "asia-south1-a"
}
___________________________
2️⃣ VPC (AWS VPC / Azure VNet Equivalent)
resource "google_compute_network" "vpc" {
  name                    = "vpc-demo"
  auto_create_subnetworks = false
}
________________________________
3️⃣ Subnets
Public Subnet
resource "google_compute_subnetwork" "public" {
  name          = "public-subnet"
  ip_cidr_range = "10.0.1.0/24"
  region        = "asia-south1"
  network       = google_compute_network.vpc.id
}
___________________________________
Private Subnet
resource "google_compute_subnetwork" "private" {
  name                     = "private-subnet"
  ip_cidr_range            = "10.0.2.0/24"
  region                   = "asia-south1"
  network                  = google_compute_network.vpc.id
  private_ip_google_access = true
}
___________________________________________
4️⃣ Cloud Router (Required for NAT)
resource "google_compute_router" "router" {
  name    = "nat-router"
  region  = "asia-south1"
  network = google_compute_network.vpc.id
}
_______________________________________
5️⃣ Cloud NAT (Azure NAT Gateway Equivalent)
resource "google_compute_router_nat" "nat" {
  name                               = "cloud-nat"
  router                             = google_compute_router.router.name
  region                             = "asia-south1"
  nat_ip_allocate_option              = "AUTO_ONLY"
  source_subnetwork_ip_ranges_to_nat  = "LIST_OF_SUBNETWORKS"

  subnetwork {
    name                    = google_compute_subnetwork.private.name
    source_ip_ranges_to_nat = ["ALL_IP_RANGES"]
  }
}
____________________________________________
In GCP, you don’t manually attach Public IP to NAT like Azure.
Cloud NAT automatically manages external IPs.
_____________________________
6️⃣ Firewall Rules (AWS SG / Azure NSG Equivalent)
Allow SSH
resource "google_compute_firewall" "allow_ssh" {
  name    = "allow-ssh"
  network = google_compute_network.vpc.name

  allow {
    protocol = "tcp"
    ports    = ["22"]
  }

  source_ranges = ["0.0.0.0/0"]
  target_tags   = ["vm-tag"]
}
______________________________
Allow HTTP
resource "google_compute_firewall" "allow_http" {
  name    = "allow-http"
  network = google_compute_network.vpc.name

  allow {
    protocol = "tcp"
    ports    = ["80"]
  }

  source_ranges = ["0.0.0.0/0"]
  target_tags   = ["vm-tag"]
}
_______________________________
7️⃣ Public VM (Equivalent to EC2 / Azure VM)
resource "google_compute_instance" "public_vm" {
  name         = "public-vm"
  machine_type = "e2-medium"
  zone         = "asia-south1-a"

  tags = ["vm-tag"]

  boot_disk {
    initialize_params {
      image = "debian-cloud/debian-12"
    }
  }

  network_interface {
    subnetwork = google_compute_subnetwork.public.id

    # Public IP
    access_config {}
  }

  metadata = {
    ssh-keys = "gcpuser:${file("~/.ssh/id_rsa.pub")}"
  }
}
_______________________________________________
8️⃣ Private VM (No Public IP – Uses NAT)
resource "google_compute_instance" "private_vm" {
  name         = "private-vm"
  machine_type = "e2-medium"
  zone         = "asia-south1-a"

  tags = ["vm-tag"]

  boot_disk {
    initialize_params {
      image = "debian-cloud/debian-12"
    }
  }

  network_interface {
    subnetwork = google_compute_subnetwork.private.id
    # ❌ No access_config → No Public IP
  }
}
_________________________
9️⃣ Outputs
output "public_vm_ip" {
  value = google_compute_instance.public_vm.network_interface[0].access_config[0].nat_ip
}
