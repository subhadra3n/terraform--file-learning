# AWS (RDS - MySQL/Postgres)                                                     # Azure (Azure Database for PostgreSQL Flexible Server)                                   # GCP (Cloud SQL - Postgres/MySQL)
terraform { required_providers { aws={source="hashicorp/aws"} } }                 terraform { required_providers { azurerm={source="hashicorp/azurerm"} } }             terraform { required_providers { google={source="hashicorp/google"} } }
provider "aws" { region="ap-south-1" }                                            provider "azurerm" { features {} }                                                      provider "google" { project="my-gcp-project-id" region="asia-south1" }

# 1️⃣ NETWORK (Private DB subnets)                                                # 1️⃣ NETWORK (VNet + delegated subnet for DB)                                            # 1️⃣ NETWORK (Private IP via Service Networking)
# Assume: vpc + 2 private subnets already exist                                  resource "azurerm_resource_group" "rg" {                                                resource "google_compute_network" "vpc" {
# private_subnet_a_id, private_subnet_b_id                                           name     = "demo-rg"                                                                      name                    = "demo-vpc"
# (RDS should be in private subnets)                                                location = "centralindia"                                                                auto_create_subnetworks = false
                                                                                  }                                                                                       }
resource "aws_db_subnet_group" "db_subnets" {                                     resource "azurerm_virtual_network" "vnet" {                                             resource "google_compute_subnetwork" "subnet" {
  name       = "demo-db-subnet-group"                                               name                = "demo-vnet"                                                         name          = "demo-subnet"
  subnet_ids = ["subnet-aaaaaaa","subnet-bbbbbbb"]  # private subnets              location            = "centralindia"                                                      region        = "asia-south1"
  tags = { Name = "demo-db-subnet-group" }                                         resource_group_name = azurerm_resource_group.rg.name                                     network       = google_compute_network.vpc.id
}                                                                                  address_space       = ["10.20.0.0/16"]                                                    ip_cidr_range = "10.30.1.0/24"
                                                                                  }                                                                                       }

                                                                                  # Delegated subnet required for Flexible Server (private access)
                                                                                  resource "azurerm_subnet" "db_subnet" {
                                                                                    name                 = "db-subnet"
                                                                                    resource_group_name  = azurerm_resource_group.rg.name
                                                                                    virtual_network_name = azurerm_virtual_network.vnet.name
                                                                                    address_prefixes     = ["10.20.10.0/24"]
                                                                                    delegation {
                                                                                      name = "pgsql-delegation"
                                                                                      service_delegation {
                                                                                        name    = "Microsoft.DBforPostgreSQL/flexibleServers"
                                                                                        actions = ["Microsoft.Network/virtualNetworks/subnets/join/action"]
                                                                                      }
                                                                                    }
                                                                                  }

                                                                                  # Private DNS zone for PostgreSQL Flexible Server
                                                                                  resource "azurerm_private_dns_zone" "pgsql" {
                                                                                    name                = "privatelink.postgres.database.azure.com"
                                                                                    resource_group_name = azurerm_resource_group.rg.name
                                                                                  }
                                                                                  resource "azurerm_private_dns_zone_virtual_network_link" "link" {
                                                                                    name                  = "dns-link"
                                                                                    private_dns_zone_name = azurerm_private_dns_zone.pgsql.name
                                                                                    virtual_network_id    = azurerm_virtual_network.vnet.id
                                                                                    resource_group_name   = azurerm_resource_group.rg.name
                                                                                  }

                                                                                                                                resource "google_compute_global_address" "psa_range" {
                                                                                                                                  name          = "psa-range"
                                                                                                                                  purpose       = "VPC_PEERING"
                                                                                                                                  address_type  = "INTERNAL"
                                                                                                                                  prefix_length = 16
                                                                                                                                  network       = google_compute_network.vpc.id
                                                                                                                                }
                                                                                                                                resource "google_service_networking_connection" "psa" {
                                                                                                                                  network                 = google_compute_network.vpc.id
                                                                                                                                  service                 = "servicenetworking.googleapis.com"
                                                                                                                                  reserved_peering_ranges = [google_compute_global_address.psa_range.name]
                                                                                                                                }

# 2️⃣ SECURITY (DB SG / inbound rules)                                            # 2️⃣ SECURITY (Private access only)                                                   # 2️⃣ SECURITY (Authorized networks OR Private IP)
resource "aws_security_group" "rds_sg" {                                          # Flexible Server uses Private DNS + delegated subnet (no public)                         # With private_ip_configuration below, no public IP is used
  name   = "rds-sg"
  vpc_id = "vpc-xxxxxxxx"
  # Allow DB port from App SG / VPC CIDR (example)
  ingress { from_port=5432 to_port=5432 protocol="tcp" cidr_blocks=["10.10.0.0/16"] }   # Postgres
  # ingress { from_port=3306 to_port=3306 protocol="tcp" cidr_blocks=["10.10.0.0/16"] } # MySQL
  egress  { from_port=0 to_port=0 protocol="-1" cidr_blocks=["0.0.0.0/0"] }
}

# 3️⃣ RDS / Managed DB Instance                                                  # 3️⃣ Azure PostgreSQL Flexible Server                                                  # 3️⃣ Cloud SQL Instance + DB + User
resource "aws_db_instance" "rds" {                                                resource "azurerm_postgresql_flexible_server" "db" {                                      resource "google_sql_database_instance" "db" {
  identifier               = "demo-rds"                                             name                   = "demo-psql-flex"                                                   name             = "demo-sql"
  engine                   = "postgres"    # or "mysql"                             resource_group_name    = azurerm_resource_group.rg.name                                     database_version = "POSTGRES_15"   # or MYSQL_8_0
  engine_version           = "15.5"        # example                                location               = "centralindia"                                                      region           = "asia-south1"
  instance_class           = "db.t3.micro"                                          version                = "15"                                                               settings {
  allocated_storage        = 20                                                     delegated_subnet_id    = azurerm_subnet.db_subnet.id                                           tier = "db-custom-1-3840"          # example tier
  storage_type             = "gp3"                                                  private_dns_zone_id    = azurerm_private_dns_zone.pgsql.id                                      availability_type = "ZONAL"
  db_subnet_group_name     = aws_db_subnet_group.db_subnets.name                    administrator_login    = "dbadmin"                                                            backup_configuration { enabled=true start_time="03:00" }
  vpc_security_group_ids   = [aws_security_group.rds_sg.id]                         administrator_password = "P@ssword123!"                                                        ip_configuration {
  publicly_accessible      = false                                                  storage_mb             = 32768                                                                  ipv4_enabled    = false
  multi_az                 = false                                                  sku_name               = "Standard_B1ms"                                                        private_network = google_compute_network.vpc.id
  backup_retention_period  = 7                                                      backup_retention_days  = 7                                                                       require_ssl     = true
  deletion_protection      = true                                                   geo_redundant_backup_enabled = false                                                             authorized_networks { name="none" value="0.0.0.0/32" } # (optional placeholder)
  skip_final_snapshot      = true                                                   depends_on = [azurerm_private_dns_zone_virtual_network_link.link]                             }
  # username/password shown for interview; in real use store in secrets           }                                                                           }
  username                 = "dbadmin"
  password                 = "P@ssword123!"
  tags = { Name="demo-rds" }
}

# Optional: Parameter group (interview mention)                                   # Optional: Firewall rules for PUBLIC mode (NOT used here)                                  resource "google_sql_database" "appdb" {
# resource "aws_db_parameter_group" "pg" { ... }                                   # resource "azurerm_postgresql_flexible_server_firewall_rule" ...                           name="appdb" instance=google_sql_database_instance.db.name
                                                                                                                                }
                                                                                                                                resource "google_sql_user" "appuser" {
                                                                                                                                  name     = "appuser"
                                                                                                                                  instance = google_sql_database_instance.db.name
                                                                                                                                  password = "P@ssword123!"
                                                                                                                                }

